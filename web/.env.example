# Public backend URL used by axios + socket.io at build time.
# This value is inlined into the production bundle, so a missing
# variable here (or in Vercel) WILL break /login and /register in
# production — the app would fall back to http://localhost:3000
# and fail with ERR_CONNECTION_REFUSED / Mixed Content / CORS errors.
#
# Local development: keep this pointing at your local backend.
VITE_API_URL=http://localhost:3000

# Admin panel URL — opened by the hidden Ctrl+Shift+Alt+Z shortcut.
# After changing this, regenerate the encoded bytes:
#   VITE_ADMIN_URL=https://your-admin.vercel.app node scripts/encode-admin-url.mjs
# and paste the output into src/hooks/useAdminShortcut.ts
VITE_ADMIN_URL=http://localhost:5174
