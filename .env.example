# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Image storage (Cloudinary)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Auth
JWT_SECRET=replace_with_random_64_char_hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_API_SECRET=your_mailjet_api_secret
MAILJET_FROM_EMAIL=verified_sender@example.com
MAILJET_FROM_NAME=PocketTrade

# Firebase Cloud Messaging (server-side)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Admin bootstrap. Required before seeding; keep real values out of Git.
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_EMAIL=

# Optional demo buyer and seeded asset URL
SEED_BUYER_EMAIL=buyer@pockettrade.local
API_PUBLIC_URL=http://localhost:3000

# Server
PORT=3000
NODE_ENV=development
# Comma-separated web origins allowed in production
CORS_ORIGINS=http://localhost:5173,https://your-admin-domain.example
