# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Image storage (Cloudinary)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Auth
JWT_SECRET=replace_with_random_64_char_hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
RESEND_API_KEY=your_resend_api_key
OTP_FROM_EMAIL=PocketTrade <otp@example.com>

# Firebase Cloud Messaging (server-side)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Admin bootstrap
# ADMIN_BOOTSTRAP_PASSWORD: Set to a secure password (min 8 chars). If left as
#   'replace_with_random_password' or shorter than 8 chars, the seed script
#   will generate a random password and print it to stdout — SAVE IT IMMEDIATELY.
#   Re-running the seed with an invalid/placeholder password re-generates a new one.
ADMIN_BOOTSTRAP_PASSWORD=replace_with_random_password
ADMIN_BOOTSTRAP_EMAIL=admin@example.com

# Server
PORT=3000
NODE_ENV=development
# Comma-separated web origins allowed in production
CORS_ORIGINS=http://localhost:5173,https://your-admin-domain.example

# Deployment (do NOT commit real values)
RENDER_API_KEY=your_render_api_key
VERCEL_TOKEN=your_vercel_token
