generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------
// 0. brand
// ----------------------------------------------------------
model Brand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("brands")
}

// ----------------------------------------------------------
// 0a. user roles
// ----------------------------------------------------------
enum UserRole {
  user
  admin
}

// ----------------------------------------------------------
// 1. users
// ----------------------------------------------------------
model User {
  id           Int            @id @default(autoincrement())
  mobileNumber String         @unique @map("mobile_number")
  email        String?        @unique @map("email")
  displayName  String?        @map("display_name")
  profileImage String?        @map("profile_image")
  location     String?
  accountStatus AccountStatus @default(active) @map("account_status")
  passwordHash String?        @map("password_hash")
  role         UserRole       @default(user)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  lastActiveAt DateTime?      @map("last_active_at")

  listings            Listing[]       @relation("Seller")
  buyerConversations  Conversation[]  @relation("Buyer")
  sellerConversations Conversation[]  @relation("Seller")
  messages            Message[]
  favorites           Favorite[]
  reportedReports     Report[]        @relation("Reporter")
  reportedUsers       Report[]        @relation("ReportedUser")

  @@index([mobileNumber])
  @@map("users")
}

enum AccountStatus {
  active
  suspended
  deleted
}

// ----------------------------------------------------------
// 2. otp_requests
// ----------------------------------------------------------
model OtpRequest {
  id           Int      @id @default(autoincrement())
  mobileNumber String   @map("mobile_number")
  hashedOtp    String   @map("hashed_otp")
  expiresAt    DateTime @map("expires_at")
  attempts     Int      @default(0)
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([mobileNumber])
  @@map("otp_requests")
}

// ----------------------------------------------------------
// 3. listings
// ----------------------------------------------------------
model Listing {
  id          Int            @id @default(autoincrement())
  sellerId    Int            @map("seller_id")
  brand       String
  model       String
  price       Int
  condition   ListingCondition
  storage     String
  colour      String?        @map("colour")
  description String         @db.Text
  location    String
  status      ListingStatus  @default(draft)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  seller        User           @relation("Seller", fields: [sellerId], references: [id], onDelete: Cascade)
  images        ListingImage[]
  conversations Conversation[]
  favoritedBy   Favorite[]
  reports       Report[]

  @@index([status, createdAt])
  @@index([brand, model])
  @@map("listings")
}

enum ListingCondition {
  brand_new
  like_new
  excellent
  good
  fair
}

enum ListingStatus {
  draft
  pending
  active
  rejected
  sold
  removed
  expired
}

// ----------------------------------------------------------
// 4. listing_images
// ----------------------------------------------------------
model ListingImage {
  id           Int    @id @default(autoincrement())
  listingId    Int    @map("listing_id")
  imageUrl     String @map("image_url")
  displayOrder Int    @default(0) @map("display_order")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

// ----------------------------------------------------------
// 5. conversations
// ----------------------------------------------------------
model Conversation {
  id            Int       @id @default(autoincrement())
  listingId     Int       @map("listing_id")
  buyerId       Int       @map("buyer_id")
  sellerId      Int       @map("seller_id")
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User      @relation("Buyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("Seller", fields: [sellerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([listingId, buyerId, sellerId])
  @@map("conversations")
}

// ----------------------------------------------------------
// 6. messages
// ----------------------------------------------------------
model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int      @map("conversation_id")
  senderId       Int      @map("sender_id")
  content        String   @db.Text
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ----------------------------------------------------------
// 7. favorites
// ----------------------------------------------------------
model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  listingId Int      @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("favorites")
}

// ----------------------------------------------------------
// 8. reports
// ----------------------------------------------------------
model Report {
  id                Int          @id @default(autoincrement())
  reporterId        Int          @map("reporter_id")
  reportedUserId    Int?         @map("reported_user_id")
  reportedListingId Int?         @map("reported_listing_id")
  reason            ReportReason
  details           String?      @db.Text
  status            ReportStatus @default(pending)
  createdAt         DateTime     @default(now()) @map("created_at")

  reporter       User      @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser   User?     @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  reportedListing Listing? @relation(fields: [reportedListingId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("reports")
}

enum ReportReason {
  spam
  counterfeit
  stolen
  inappropriate
  scam
  other
}

enum ReportStatus {
  pending
  reviewed
  dismissed
}

// ----------------------------------------------------------
// 9. search_logs
// ----------------------------------------------------------
model SearchLog {
  id          Int      @id @default(autoincrement())
  searchTerm  String   @map("search_term")
  filters     Json?
  resultCount Int      @map("result_count")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([searchTerm])
  @@map("search_logs")
}

// ----------------------------------------------------------
// 10. admin_activity_logs
// ----------------------------------------------------------
model AdminActivityLog {
  id            Int      @id @default(autoincrement())
  adminId       String   @map("admin_id")
  action        String
  targetType    String   @map("target_type")
  targetId      String   @map("target_id")
  previousValue Json?    @map("previous_value")
  newValue      Json?    @map("new_value")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([targetType, targetId])
  @@map("admin_activity_logs")
}